{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ScenarioInput",
  "description": "Standardized input scenario for all three baselines.",
  "type": "object",
  "required": ["scenario_id", "tier", "tier_name", "action_type", "requested_by", "performed_by", "targets"],
  "properties": {
    "scenario_id": {
      "type": "string",
      "description": "Unique identifier matching the filename stem"
    },
    "tier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9
    },
    "tier_name": {
      "type": "string"
    },
    "action_type": {
      "type": "string",
      "enum": ["RestartServerAction", "DeployAction", "QueryLogsAction", "SkillInvocation"]
    },
    "requested_by": {"type": "string"},
    "performed_by": {"type": "string"},
    "targets": {"type": "string"},
    "linked_to_ticket": {"type": "string"},
    "has_audit_obligation": {"type": "boolean"},
    "has_break_glass_exception": {"type": "boolean"},
    "disclosure_state": {"type": "string"},
    "reason": {"type": "string"},
    "change_tickets": {
      "type": "array",
      "items": {"type": "object"}
    },
    "exceptions": {
      "type": "array",
      "items": {"type": "object"}
    },
    "instructions": {
      "type": "array",
      "items": {"type": "object"}
    }
  }
}
