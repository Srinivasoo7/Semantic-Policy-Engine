@prefix : <http://example.org/agent-policy#> .
:action_restart_in_window a :RestartServerAction ;
    :requestedBy :user_123 ; :performedBy :agent_01 ;
    :targets :srv_123 ;
    :hasMaintenanceWindow :srv_123_maintenance ;
    :hasChangeTicket :CHG_APPROVED ;
    :hasReason "restart during active maintenance window" .

:CHG_APPROVED a :ChangeTicket ;
    :hasStatus :Approved .
