@prefix : <http://example.org/agent-policy#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

#################################################################
# Classes
#################################################################

:AgentAction a owl:Class .
:ToolInvocation a owl:Class ; rdfs:subClassOf :AgentAction .
:SkillInvocation a owl:Class ; rdfs:subClassOf :AgentAction .

:RestartServerAction a owl:Class ; rdfs:subClassOf :ToolInvocation .
:DisruptiveAction a owl:Class .

:Server a owl:Class .
:ProductionServer a owl:Class .
:StagingServer a owl:Class .
:CriticalInfrastructureAsset a owl:Class .

:Service a owl:Class .
:PaymentService a owl:Class ; rdfs:subClassOf :Service .
:CustomerFacingService a owl:Class .

:Incident a owl:Class .
:ChangeTicket a owl:Class .
:Exception a owl:Class .
:ActiveBreakGlassException a owl:Class ; rdfs:subClassOf :Exception .

:User a owl:Class .
:Agent a owl:Class .

:Skill a owl:Class ; rdfs:subClassOf prov:Entity .
:Tool a owl:Class .
:PaymentTool a owl:Class ; rdfs:subClassOf :Tool .
:RiskySkill a owl:Class .
:UnverifiedSkill a owl:Class .
:CredentialExfiltrationInstruction a owl:Class .
:MaliciousSkillInstruction a owl:Class .

#################################################################
# Individuals / constants
#################################################################

:production a owl:NamedIndividual .
:staging a owl:NamedIndividual .
:Approved a owl:NamedIndividual .
:Unverified a owl:NamedIndividual .
:Verified a owl:NamedIndividual .
:advertised a owl:NamedIndividual .
:loaded a owl:NamedIndividual .
:FinanceWriteAccess a owl:NamedIndividual .
:AdminSecretAccess a owl:NamedIndividual .

#################################################################
# Properties
#################################################################

:requestedBy a owl:ObjectProperty .
:performedBy a owl:ObjectProperty .
:targets a owl:ObjectProperty .
:linkedToTicket a owl:ObjectProperty .
:hasChangeTicket a owl:ObjectProperty .
:hasException a owl:ObjectProperty .
:hasStatus a owl:ObjectProperty .
:hosts a owl:ObjectProperty .
:belongsToEnvironment a owl:ObjectProperty .
:affectsService a owl:ObjectProperty .
:hasSeverity a owl:ObjectProperty .
:hasCriticality a owl:ObjectProperty .
:declaresTool a owl:ObjectProperty .
:requiresPermission a owl:ObjectProperty .
:hasDisclosureState a owl:ObjectProperty .
:hasInstruction a owl:ObjectProperty .
:hasVerificationStatus a owl:ObjectProperty .
:hasReason a owl:DatatypeProperty .
:hasTag a owl:DatatypeProperty .
:hasAuditObligation a owl:DatatypeProperty .

#################################################################
# OWL equivalence / inference rules
#################################################################

:ProductionServer owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Server
        [ a owl:Class ;
          owl:unionOf (
              [ a owl:Restriction ;
                owl:onProperty :belongsToEnvironment ;
                owl:hasValue :production ]
              [ a owl:Restriction ;
                owl:onProperty :hasCriticality ;
                owl:hasValue :customer_facing ]
              [ a owl:Restriction ;
                owl:onProperty :hasTag ;
                owl:hasValue "prod-like" ]
              [ a owl:Restriction ;
                owl:onProperty :hasTag ;
                owl:hasValue "pci-dss" ]
          )
        ]
    )
] .

:StagingServer owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Server
        [ a owl:Restriction ;
          owl:onProperty :belongsToEnvironment ;
          owl:hasValue :staging ]
    )
] .

:ProductionServer rdfs:subClassOf :CriticalInfrastructureAsset .
:PaymentService rdfs:subClassOf :CustomerFacingService .
:RestartServerAction rdfs:subClassOf :DisruptiveAction .

:UnverifiedSkill owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Skill
        [ a owl:Restriction ;
          owl:onProperty :hasVerificationStatus ;
          owl:hasValue :Unverified ]
    )
] .

:PaymentTool owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
        :Tool
        [ a owl:Restriction ;
          owl:onProperty :requiresPermission ;
          owl:hasValue :FinanceWriteAccess ]
    )
] .
